<Window x:Class="RehobothMediaPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Rehoboth Media Pro" Height="768" Width="1366"
        WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <!-- GLOBAL ROUNDED BUTTON STYLE -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SIDEBAR GLOW & ACTIVE STYLE -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="WhiteSmoke"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="10,5,10,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="Active">
                                <Setter Property="Background" Value="#2D3047"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6C5DD3"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- BIBLE CHAPTER PREVIEW TEMPLATES -->
        <DataTemplate x:Key="SingleLangTemplate">
            <StackPanel Margin="5,5,5,15">
                <TextBlock Text="{Binding PrimaryText}" TextWrapping="Wrap" FontSize="14" Foreground="WhiteSmoke" VerticalAlignment="Top"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="DualLangTemplate">
            <Grid Margin="5,5,5,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                    <!-- The Gap -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding PrimaryText}" TextWrapping="Wrap" FontSize="14" Foreground="WhiteSmoke" VerticalAlignment="Top"/>

                <!-- FIX: Line is now locked INSIDE the gap! It will never touch the text. -->
                <Border Grid.Column="1" Width="1" Background="#2D3047" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="0,5"/>

                <TextBlock Grid.Column="2" Text="{Binding SecondaryText}" TextWrapping="Wrap" FontSize="14" Foreground="WhiteSmoke" VerticalAlignment="Top"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Border Background="#0F111A" CornerRadius="15" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.ColumnSpan="2" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <!-- NEW HAMBURGER BUTTON -->
                    <Button Content="☰" Width="40" Height="40" Background="Transparent" Foreground="White" FontSize="20" BorderThickness="0" HorizontalAlignment="Left" Margin="10,0,0,0" Cursor="Hand" Click="BtnToggleSidebar_Click"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                        <Button Content="—" Width="30" Height="30" Background="Transparent" Foreground="Gray" Click="BtnMinimize_Click"/>
                        <Button Content="✕" Width="30" Height="30" Background="Transparent" Foreground="Gray" Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- LEFT SIDEBAR WRAPPER -->
            <Grid x:Name="SidebarWrapper" Grid.Row="1" Grid.Column="0" Width="255" ClipToBounds="True">
                <Border Background="#1C1E30" CornerRadius="10" Margin="15,0,0,15" Width="240" HorizontalAlignment="Left">
                    <StackPanel Margin="0,20,0,0">
                        <TextBlock Text="Rehoboth Media" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="P R O" Foreground="#6C5DD3" FontSize="11" FontWeight="Heavy" HorizontalAlignment="Center" Margin="0,0,0,30" />

                        <Button x:Name="BtnMenuSongs" Content="🎵 Songs &amp; Lyrics" Style="{StaticResource MenuButton}" Click="BtnNavSongs_Click"/>
                        <Button x:Name="BtnMenuBible" Content="📖 VerseView Bible" Style="{StaticResource MenuButton}" Click="BtnNavBible_Click"/>
                        <Button x:Name="BtnMenuLowerThird" Content="📺 Lower Thirds" Style="{StaticResource MenuButton}" Click="BtnNavLowerThird_Click"/>
                        <Button x:Name="BtnMenuBirthdays" Content="🎂 Birthdays &amp; Anniversaries" Style="{StaticResource MenuButton}" Click="BtnNavBirthdays_Click"/>
                        <Button x:Name="BtnMenuRemote" Content="📱 Mobile Remote" Style="{StaticResource MenuButton}" Click="BtnNavRemote_Click"/>
                        <!-- NEW SETTINGS BUTTON -->
                        <Button x:Name="BtnMenuSettings" Content="⚙️ Settings" Style="{StaticResource MenuButton}" Margin="10,270,10,5" Click="BtnNavSettings_Click"/>
                    </StackPanel>
                   </Border>
            </Grid>

            <!-- MAIN CONTENT AREA -->
            <Border Grid.Row="1" Grid.Column="1" Background="#1C1E30" CornerRadius="10" Margin="15,0,15,15" Padding="20" PreviewMouseDown="MainContent_PreviewMouseDown">
                <Grid>

                    <!-- ======================================================= -->
                    <!-- 42 RULE LOCKED: SONG DASHBOARD -->
                    <!-- ======================================================= -->
                    <Grid x:Name="SongDashboard" Visibility="Visible">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="350"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ComboBox x:Name="SongDropdownList" SelectionChanged="SongDropdownList_SelectionChanged" KeyUp="SongDropdownList_KeyUp" IsTextSearchEnabled="False" StaysOpenOnEdit="True" Height="35" Margin="0,0,0,15" FontSize="14" IsEditable="True" Background="White" Foreground="Black" Padding="5"/>
                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="🌐 Fetch Web" Height="30" Background="#0085FF" Margin="0,0,10,0" Click="BtnFetchWeb_Click"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="Font Size:" Foreground="LightGray" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="FontSizeBox" Text="45" Width="40" Height="30" TextAlignment="Center" Background="#2D3047" Foreground="White" BorderThickness="0" VerticalContentAlignment="Center"/>
                                    <Button Content="+" Width="30" Height="30" Background="#2D3047" Margin="2,0,0,0" Click="BtnIncreaseFont_Click"/>
                                    <Button Content="-" Width="30" Height="30" Background="#2D3047" Margin="2,0,0,0" Click="BtnDecreaseFont_Click"/>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="2" Background="#0F111A" CornerRadius="12" Margin="0,0,0,15" Padding="10">
                                <TextBox x:Name="LyricsInputBox" CaretBrush="White" Background="Transparent" Foreground="White" FontSize="14" AcceptsReturn="True" TextWrapping="Wrap" BorderThickness="0" />
                            </Border>

                            <Grid Grid.Row="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="🗑 Delete" Width="80" Height="35" Background="#FF4757" Margin="0,0,10,0" Click="BtnDelete_Click"/>
                                <Button Grid.Column="1" Content="💾 Save" Width="80" Height="35" Background="#00B478" Click="BtnSave_Click"/>
                                <Button Grid.Column="3" Content="🚀 SUBMIT" Width="100" Height="35" Background="#6C5DD3" Click="BtnSubmit_Click"/>
                            </Grid>
                        </Grid>

                        <Border Grid.Column="1" Background="#0F111A" CornerRadius="8" Margin="20,0,0,0" Padding="15" ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- FIX: Split Checkboxes and Buttons so they never get pushed off screen! -->
                                <Grid Grid.Row="0" Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <CheckBox x:Name="chkPresentation" Content="Presentation Mode" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,8" Click="ChkPresentation_Click"/>
                                        <CheckBox x:Name="chkDualDisplay" Content="Enable Dual Monitors" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="✨ THEME" Height="35" Padding="10,0" Background="#6C5DD3" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" Cursor="Hand" Click="BtnThemeLogo_Click"/>
                                        <Button Content="📺 OPEN LIVE DISPLAY" Height="35" Padding="15,0" Background="#FF9F43" Foreground="Black" FontWeight="Bold" Margin="0,0,10,0" Cursor="Hand" Click="BtnOpenLive_Click"/>
                                        <Button Content="🟩 GREEN SCREEN" Height="35" Padding="15,0" Background="#00B478" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" Cursor="Hand" Click="BtnGreenScreen_Click"/>
                                        <Button Content="✕ CLOSE" Height="35" Padding="15,0" Background="#FF4757" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnCloseLive_Click"/>
                                    </StackPanel>
                                </Grid>

                                <UniformGrid x:Name="LyricsButtonGrid" Grid.Row="1" Columns="5" Rows="8" VerticalAlignment="Top"/>
                            </Grid>
                        </Border>
                    </Grid>


                    <!-- ======================================================= -->
                    <!-- VERSEVIEW BIBLE DASHBOARD -->
                    <!-- ======================================================= -->
                    <Grid x:Name="BibleDashboard" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT COLUMN: Controls -->
                        <Border Grid.Column="0" Background="#0F111A" CornerRadius="10" Padding="15" Margin="0,0,15,0">
                            <StackPanel>
                                <TextBlock Text="Smart Search" Foreground="#6C5DD3" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                                <TextBlock Text="e.g. 'Gen', 'Est 1', or '1 jo 1 1'" Foreground="LightGray" FontSize="11" Margin="0,0,0,5"/>
                                <Border Background="#1C1E30" CornerRadius="8" BorderThickness="1" BorderBrush="#6C5DD3" Margin="0,0,0,15" Padding="10,0">
                                    <TextBox x:Name="BibleSearchBox" Height="30" Background="Transparent" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" VerticalContentAlignment="Center" KeyDown="BibleSearchBox_KeyDown" PreviewMouseDown="BibleSearchBox_PreviewMouseDown" CaretBrush="White"/>
                                </Border>

                                <TextBlock Text="Languages" Foreground="#6C5DD3" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                                <Button Content="↕ SWAP PRI/SEC" Height="25" Background="#2D3047" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnSwapLanguages_Click" Margin="0,0,0,10"/>
                                <!-- FIX: Added Click events to instantly update when checked/unchecked! -->
                                <CheckBox x:Name="chkTamil" Content="Tamil Bible" Foreground="White" IsChecked="True" Margin="0,3" Click="LanguageCheckbox_Click"/>
                                <CheckBox x:Name="chkEnglish" Content="English Bible" Foreground="White" Margin="0,3" Click="LanguageCheckbox_Click"/>
                                <CheckBox x:Name="chkHindi" Content="Hindi Bible" Foreground="White" Margin="0,3" Click="LanguageCheckbox_Click"/>
                                <CheckBox x:Name="chkMarathi" Content="Marathi Bible" Foreground="White" Margin="0,3" Click="LanguageCheckbox_Click"/>

                                <TextBlock Text="Custom Styling" Foreground="#6C5DD3" FontWeight="Bold" FontSize="14" Margin="0,15,0,5"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Verse Font:" Foreground="LightGray" FontSize="11" Grid.Row="0" Grid.Column="0"/>
                                    <ComboBox x:Name="CbVerseFont" Grid.Row="1" Grid.Column="0" Margin="0,0,5,5" SelectionChanged="BibleStyle_Changed"/>
                                    <TextBlock Text="Verse Color:" Foreground="LightGray" FontSize="11" Grid.Row="0" Grid.Column="1"/>
                                    <ComboBox x:Name="CbVerseColor" Grid.Row="1" Grid.Column="1" Margin="5,0,0,5" SelectionChanged="BibleStyle_Changed"/>
                                    <TextBlock Text="Ref Font:" Foreground="LightGray" FontSize="11" Grid.Row="2" Grid.Column="0"/>
                                    <ComboBox x:Name="CbRefFont" Grid.Row="3" Grid.Column="0" Margin="0,0,5,0" SelectionChanged="BibleStyle_Changed"/>
                                    <TextBlock Text="Ref Color:" Foreground="LightGray" FontSize="11" Grid.Row="2" Grid.Column="1"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="Font Size Override:" Foreground="LightGray" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <Button Content="+" Width="30" Height="30" Background="#2D3047" Margin="0,0,3,0" Click="BtnBibleFontUp_Click"/>
                                    <Button Content="-" Width="30" Height="30" Background="#2D3047" Margin="0,0,3,0" Click="BtnBibleFontDown_Click"/>
                                    <Button Content="↺" Width="30" Height="30" Background="#FF4757" Click="BtnBibleFontReset_Click"/>
                                </StackPanel>

                                <TextBlock Text="Background Image" Foreground="#6C5DD3" FontWeight="Bold" FontSize="14" Margin="0,5,0,10"/>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="🖼️ Browse" Height="30" Background="#2D3047" Foreground="White" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand" Click="BtnBrowseBg_Click"/>
                                    <Button Grid.Column="1" Content="❌ Remove" Height="30" Background="#FF4757" Foreground="White" Margin="5,0,0,0" BorderThickness="0" Cursor="Hand" Click="BtnRemoveBg_Click"/>
                                </Grid>
                                <TextBlock x:Name="LblBgStatus" Text="Solid Black" Foreground="Gray" FontSize="11" Margin="0,0,0,15" TextWrapping="Wrap"/>
                                <TextBlock Text="Recent Verses" Foreground="#6C5DD3" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                                <Border Background="#1C1E30" CornerRadius="5" Padding="5" Height="135">
                                    <ListBox x:Name="HistoryList" Background="Transparent" BorderThickness="0" Foreground="White" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="HistoryList_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Padding="5" Cursor="Hand" FontSize="12"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- RIGHT COLUMN: Massive Chapter Preview & Live Controls -->
                        <Border Grid.Column="1" Background="#1C1E30" CornerRadius="10" Padding="20" Margin="0,0,15,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <!-- Top Controls -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Title -->
                                    <RowDefinition Height="*"/>
                                    <!-- Chapter List -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Bottom Controls -->
                                </Grid.RowDefinitions>

                                <!-- Top: Live Display Controls -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
                                    <Button Content="📺 OPEN LIVE DISPLAY" Height="35" Padding="15,0" Background="#FF9F43" Foreground="Black" FontWeight="Bold" Margin="0,0,10,0" Cursor="Hand" Click="BtnOpenLive_Click"/>
                                    <Button Content="🟩 GREEN SCREEN" Height="35" Padding="15,0" Background="#00B478" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" Cursor="Hand" Click="BtnGreenScreen_Click"/>
                                    <Button Content="✕ CLOSE" Height="35" Padding="15,0" Background="#FF4757" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnCloseLive_Click"/>
                                </StackPanel>

                                <!-- Chapter Title -->
                                <TextBlock x:Name="LblChapterTitle" Grid.Row="1" Text="Chapter Preview" Foreground="#00B478" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                                <!-- FIX: Removed the buggy background line. The ListBox now stretches 100% width! -->
                                <ListBox x:Name="ChapterVerseList" Grid.Row="2" Background="Transparent" BorderThickness="0" Foreground="White" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="ChapterVerseList_SelectionChanged" HorizontalContentAlignment="Stretch">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="VerticalContentAlignment" Value="Top"/>
                                            <!-- THIS IS THE MAGIC FIX: Forces perfect alignment down the whole screen -->
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="BorderBrush" Value="#2D3047"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="Padding" Value="10"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>

                                <!-- Bottom: Prev/Next Controls -->
                                <Grid Grid.Row="3" Margin="0,20,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="⬅️ PREV VERSE" Height="45" Background="#2D3047" FontWeight="Bold" Click="BtnPrevVerse_Click"/>
                                    <Button Grid.Column="2" Content="NEXT VERSE ➡️" Height="45" Background="#2D3047" FontWeight="Bold" Click="BtnNextVerse_Click"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                    <!-- ======================================================= -->
                    <!-- MOBILE REMOTE DASHBOARD -->
                    <!-- ======================================================= -->
                    <Grid x:Name="RemoteDashboard" Visibility="Collapsed">
                        <Border Background="#0F111A" CornerRadius="10" Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="📱 Mobile Remote Control" Foreground="#6C5DD3" FontWeight="Bold" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Control the live stream lyrics and bible verses directly from your phone!" Foreground="LightGray" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                                <Button x:Name="BtnToggleServer" Content="🚀 START SERVER" Height="50" Width="250" Background="#00B478" Foreground="White" FontWeight="Bold" FontSize="16" Cursor="Hand" Click="BtnToggleServer_Click"/>

                                <StackPanel x:Name="ServerInfoPanel" Visibility="Collapsed" Margin="0,40,0,0">
                                    <TextBlock Text="Server is Running! Open this URL on your phone:" Foreground="#00B478" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBox x:Name="ServerUrlBox" Text="http://192.168.1.5:8080/" Background="#1C1E30" Foreground="White" FontSize="24" FontWeight="Bold" TextAlignment="Center" BorderThickness="0" IsReadOnly="True" Margin="0,0,0,20"/>
                                    <TextBlock Text="(Make sure your phone is connected to the same Wi-Fi as this computer)" Foreground="Gray" FontSize="12" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <!-- ======================================================= -->
                    <!-- LOWER THIRDS DASHBOARD (With True Live Monitor!) -->
                    <!-- ======================================================= -->
                    <Grid x:Name="LowerThirdDashboard" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="380"/>
                            <!-- Left: 4 Media Cards -->
                            <ColumnDefinition Width="*"/>
                            <!-- Right: True Live Monitor -->
                        </Grid.ColumnDefinitions>

                        <!-- LEFT COLUMN: The Media Cards -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,15,0">
                            <StackPanel Margin="0,0,10,0">

                                <!-- CARD 1: Broadcast Customizer -->
                                <Border Background="#1C1E30" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Broadcast Customizer" Foreground="#6C5DD3" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Theme Style:" Foreground="LightGray" FontSize="11" Grid.Row="0" Grid.Column="0"/>
                                            <ComboBox x:Name="CbLtTheme" Grid.Row="1" Grid.Column="0" Margin="0,0,0,10" Background="White" Foreground="Black">
                                                <ComboBoxItem Content="Indigo (Classic)" Tag="linear-gradient(135deg, #4A00E0, #8E2DE2)"/>
                                                <ComboBoxItem Content="Crimson (News)" Tag="linear-gradient(135deg, #ff0844, #ffb199)"/>
                                                <ComboBoxItem Content="Emerald (Fresh)" Tag="linear-gradient(135deg, #11998e, #38ef7d)"/>
                                                <ComboBoxItem Content="Midnight (Sleek)" Tag="#1A1A1A"/>
                                            </ComboBox>

                                            <TextBlock Text="Accent Line:" Foreground="LightGray" FontSize="11" Grid.Row="0" Grid.Column="2"/>
                                            <ComboBox x:Name="CbLtAccent" Grid.Row="1" Grid.Column="2" Margin="0,0,0,10" Background="White" Foreground="Black">
                                                <ComboBoxItem Content="Cyan" Tag="#00E5FF"/>
                                                <ComboBoxItem Content="Gold" Tag="#FFD700"/>
                                                <ComboBoxItem Content="White" Tag="#FFFFFF"/>
                                                <ComboBoxItem Content="Red" Tag="#FF4757"/>
                                            </ComboBox>

                                            <TextBlock Text="Font Style:" Foreground="LightGray" FontSize="11" Grid.Row="2" Grid.Column="0"/>
                                            <ComboBox x:Name="CbLtFont" Grid.Row="3" Grid.Column="0" Margin="0,0,0,10" Background="White" Foreground="Black">
                                                <ComboBoxItem Content="Segoe UI"/>
                                                <ComboBoxItem Content="Impact"/>
                                                <ComboBoxItem Content="Trebuchet MS"/>
                                                <ComboBoxItem Content="Georgia"/>
                                            </ComboBox>

                                            <TextBlock Text="Animation Design:" Foreground="LightGray" FontSize="11" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"/>
                                            <ComboBox x:Name="CbLtDesign" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Background="White" Foreground="Black">
                                                <ComboBoxItem Content="1. Broadcast (Slide Left)"/>
                                                <ComboBoxItem Content="2. Minimalist (Line Expand)"/>
                                                <ComboBoxItem Content="3. Elegant (Center Fade up)"/>
                                                <ComboBoxItem Content="4. Clean Glass (Blur Drop)"/>
                                                <ComboBoxItem Content="5. Neon Cyber (Glowing Edges)"/>
                                                <ComboBoxItem Content="6. Corporate Sharp (Bottom Up)"/>
                                                <ComboBoxItem Content="7. News Ticker (Full Width)"/>
                                                <ComboBoxItem Content="8. Bouncing Pill (Pop In)"/>
                                                <ComboBoxItem Content="9. Split Horizon (Double Line)"/>
                                                <ComboBoxItem Content="10. Cinematic (Slow Zoom)"/>
                                                <ComboBoxItem Content="11. Minimal Outline (Box Draw)"/>
                                                <ComboBoxItem Content="12. Right-Side Frosted (Slide Right)"/>
                                                <ComboBoxItem Content="13. Bold Block (Heavy Drop)"/>
                                                <ComboBoxItem Content="14. Elegant Ribbon (Fade Right)"/>
                                                <ComboBoxItem Content="15. Dynamic Tech (Skewed)"/>
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- CARD 2: Text & Titles -->
                                <Border Background="#1C1E30" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Text &amp; Titles (Pastor Names)" Foreground="#6C5DD3" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                                        <TextBlock Text="Primary Name:" Foreground="LightGray" FontSize="11" Margin="0,0,0,5"/>
                                        <ComboBox x:Name="CbLtText" Height="35" Background="White" Foreground="Black" FontSize="14" IsEditable="True" Margin="0,0,0,10" Padding="5"/>
                                        <TextBlock Text="Subtitle / Role (Optional):" Foreground="LightGray" FontSize="11" Margin="0,0,0,5"/>
                                        <Border Background="White" CornerRadius="4" Margin="0,0,0,15">
                                            <TextBox x:Name="TxtLtRole" Height="30" Background="Transparent" Foreground="Black" FontSize="14" BorderThickness="0" Padding="5" VerticalContentAlignment="Center"/>
                                        </Border>
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="➕ Add Name" Height="30" Background="#2D3047" Cursor="Hand" Click="BtnAddLtText_Click"/>
                                            <Button Grid.Column="2" Content="❌ Remove" Height="30" Background="#FF4757" Cursor="Hand" Click="BtnRemoveLtText_Click"/>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="👁 PREVIEW" Height="35" Background="#FF9F43" Foreground="Black" FontWeight="Bold" Cursor="Hand" Click="BtnPreviewLtText_Click"/>
                                            <Button Grid.Column="2" x:Name="BtnSubmitLtText" Content="🚀 GO LIVE!" Height="35" Background="#00B478" FontWeight="Bold" Cursor="Hand" Click="BtnSubmitLtText_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- CARD 3: Images & Logos (RESTORED!) -->
                                <Border Background="#1C1E30" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Images &amp; Logos" Foreground="#6C5DD3" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="🖼️ Browse Image" Height="35" Background="#2D3047" Cursor="Hand" Click="BtnBrowseLtImage_Click"/>
                                            <CheckBox x:Name="chkLtPortrait" Grid.Column="2" Content="Portrait Mode" Foreground="White" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="👁 PREVIEW" Height="35" Background="#FF9F43" Foreground="Black" FontWeight="Bold" Cursor="Hand" Click="BtnPreviewLtImage_Click"/>
                                            <Button Grid.Column="2" Content="🚀 PUSH LIVE" Height="35" Background="#00B478" FontWeight="Bold" Cursor="Hand" Click="BtnSubmitLtImage_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- CARD 4: Video Animations (FIXED BUTTONS!) -->
                                <Border Background="#1C1E30" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Video Animations (MP4)" Foreground="#6C5DD3" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                                        <ComboBox x:Name="CbLtVideo" Height="35" Background="White" Foreground="Black" FontSize="14" Margin="0,0,0,10" Padding="5"/>
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="📂 Browse New" Height="30" Background="#2D3047" Cursor="Hand" Click="BtnBrowseLtVideo_Click"/>
                                            <Button Grid.Column="2" Content="❌ Remove" Height="30" Background="#FF4757" Cursor="Hand" Click="BtnRemoveLtVideo_Click"/>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="👁 PREVIEW" Height="35" Background="#FF9F43" Foreground="Black" FontWeight="Bold" Cursor="Hand" Click="BtnPreviewLtVideo_Click"/>
                                            <Button Grid.Column="2" Content="🚀 PUSH LIVE" Height="35" Background="#00B478" FontWeight="Bold" Cursor="Hand" Click="BtnSubmitLtVideo_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>

                        <!-- RIGHT COLUMN: TRUE LIVE MONITOR & Controls -->
                        <Border Grid.Column="1" Background="#0F111A" CornerRadius="10" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Live Controls -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
                                    <Button Content="📺 OPEN LIVE DISPLAY" Height="35" Width="180" Background="#FF9F43" Foreground="Black" FontWeight="Bold" Margin="0,0,10,0" Cursor="Hand" Click="BtnOpenLive_Click"/>
                                    <Button Content="🟩 GREEN SCREEN" Height="35" Width="140" Background="#00B478" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" Cursor="Hand" Click="BtnGreenScreen_Click"/>
                                    <Button Content="✕ CLOSE" Height="35" Width="100" Background="#FF4757" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnCloseLive_Click"/>
                                </StackPanel>

                                <!-- NEW: The Embedded Live Monitor! -->
                                <Border Grid.Row="1" Background="#1C1E30" CornerRadius="10" Margin="0,15" ClipToBounds="True">
                                    <wv2:WebView2 x:Name="MiniPreviewMonitor" />
                                </Border>

                                <!-- Unified Video Media Controls -->
                                <StackPanel Grid.Row="2" Margin="0,15,0,0">
                                    <TextBlock Text="Video Playback Controls:" Foreground="#6C5DD3" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Seek:" Foreground="LightGray" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                        <!-- The Magical Syncing Slider! -->
                                        <Slider x:Name="VideoSeekBar" Grid.Column="1" Minimum="0" Maximum="100" Value="0" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" Cursor="Hand" ValueChanged="VideoSeekBar_ValueChanged"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- PREVIEW Controls -->
                                        <Button x:Name="BtnPreviewPlayPause" Grid.Column="0" Content="⏸ PAUSE PREVIEW" Height="40" Background="#FF9F43" Foreground="Black" FontWeight="Bold" FontSize="14" Cursor="Hand" Click="BtnPreviewPlayPause_Click"/>
                                        <!-- LIVE Controls -->
                                        <Button x:Name="BtnLtPlayPause" Grid.Column="2" Content="⏸ PAUSE LIVE" Height="40" Background="#6C5DD3" FontWeight="Bold" FontSize="14" Cursor="Hand" Click="BtnLtPlayPause_Click"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ======================================================= -->
                    <!-- BIRTHDAYS & ANNIVERSARIES DASHBOARD (Editable!) -->
                    <!-- ======================================================= -->
                    <Grid x:Name="BirthdayDashboard" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- TOP: Database Controls & Live Display -->
                        <Grid Grid.Row="0" Margin="0,0,0,15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- ROW 1: Import, Load, and Search -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
                                <Button Content="📂 IMPORT EXCEL TO DB" Height="35" Width="180" Background="#6C5DD3" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnImportExcel_Click" Margin="0,0,10,0"/>
                                <Button Content="📅 LOAD THIS WEEK" Height="35" Width="150" Background="#00B478" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnLoadWeek_Click" Margin="0,0,10,0"/>
                                <Button Content="🗃️ VIEW ENTIRE DB" Height="35" Width="140" Background="#2D3047" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnLoadAll_Click" Margin="0,0,25,0"/>

                                <TextBlock Text="🔍 Search:" Foreground="LightGray" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
                                <TextBox x:Name="EventSearchBox" Width="130" Height="35" Background="#1C1E30" Foreground="White" BorderThickness="1,1,0,1" BorderBrush="#6C5DD3" Padding="10,0" VerticalContentAlignment="Center" CaretBrush="White" KeyDown="EventSearchBox_KeyDown"/>
                                <Button Content="Search" Width="60" Height="35" Background="#6C5DD3" Foreground="White" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Click="BtnEventSearch_Click"/>
                                <Button Content="↩ UNDO SAVE" Width="100" Height="35" Background="#FF4757" Foreground="White" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Margin="10,0,0,0" Click="BtnUndoEventSave_Click"/>
                                <Border Background="#1C1E30" CornerRadius="8" Padding="10,5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Custom Fonts:" Foreground="#E91E63" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <Button Content="Change Title Font" Height="25" Padding="10,0" Background="#2D3047" Foreground="White" Cursor="Hand" Margin="0,0,5,0" Click="BtnUploadTitleFont_Click"/>
                                        <Button Content="Change Name Font" Height="25" Padding="10,0" Background="#2D3047" Foreground="White" Cursor="Hand" Click="BtnUploadNameFont_Click"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ROW 2: Live Controls & Scroller -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Border Background="#1C1E30" CornerRadius="8" Padding="10,5" Margin="0,0,15,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Scroll Speed:" Foreground="LightGray" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <Slider x:Name="EventScrollSpeed" Width="80" Minimum="1" Maximum="10" Value="5" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                        <Button x:Name="BtnEventScroll" Content="▶ START SCROLL" Height="25" Padding="10,0" Background="#2D3047" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnEventScroll_Click"/>
                                    </StackPanel>
                                </Border>

                                <Button Content="📺 OPEN LIVE DISPLAY" Height="35" Padding="15,0" Background="#FF9F43" Foreground="Black" FontWeight="Bold" Margin="0,0,10,0" Cursor="Hand" Click="BtnOpenLive_Click"/>
                                <Button Content="🟩 GREEN SCREEN" Height="35" Padding="15,0" Background="#00B478" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" Cursor="Hand" Click="BtnGreenScreen_Click"/>
                                <Button Content="✕ CLOSE" Height="35" Padding="15,0" Background="#FF4757" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnCloseLive_Click"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- LEFT: Birthdays Editable Grid -->
                            <Border Grid.Column="0" Background="#1C1E30" CornerRadius="10" Padding="20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="🎂 Birthdays (Double-click to edit!)" Foreground="#00E5FF" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                                    <!-- FIX: DataGrid allows you to instantly edit names/dates to fix typos! -->
                                    <DataGrid x:Name="GridBdays" Grid.Row="1" SelectionChanged="GridBdays_SelectionChanged" AutoGenerateColumns="False" Background="#0F111A" Foreground="Black" RowBackground="White" AlternatingRowBackground="#F0F0F0" HeadersVisibility="Column" CanUserAddRows="True" Margin="0,0,0,15">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="120"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <Grid Grid.Row="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="5"/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="5"/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="5"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="❌ Clear Screen" Height="40" Background="#FF9F43" FontWeight="Bold" Cursor="Hand" Click="BtnClearBdays_Click"/>
                                        <Button x:Name="BtnDelBdayRow" Grid.Column="2" Content="🗑 Delete Row" Height="40" Background="#FF4757" FontWeight="Bold" Cursor="Hand" Click="BtnDeleteBdayRow_Click" Visibility="Hidden"/>
                                        <Button Grid.Column="4" Content="💾 UPDATE DB" Height="40" Background="#2D3047" FontWeight="Bold" Cursor="Hand" Click="BtnSaveBdayDb_Click"/>
                                        <Button Grid.Column="6" Content="🚀 PUSH LIVE" Height="40" Background="#00B478" FontWeight="Bold" Cursor="Hand" Click="BtnSubmitBdays_Click"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- RIGHT: Anniversaries Editable Grid -->
                            <Border Grid.Column="2" Background="#1C1E30" CornerRadius="10" Padding="20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="💍 Anniversaries (Double-click to edit!)" Foreground="#E91E63" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                                    <DataGrid x:Name="GridAnnivs" Grid.Row="1" SelectionChanged="GridAnnivs_SelectionChanged" AutoGenerateColumns="False" Background="#0F111A" Foreground="Black" RowBackground="White" AlternatingRowBackground="#F0F0F0" HeadersVisibility="Column" CanUserAddRows="True" Margin="0,0,0,15">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Couple Names" Binding="{Binding Name}" Width="*"/>
                                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="120"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <Grid Grid.Row="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="5"/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="5"/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="5"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="❌ Clear Screen" Height="40" Background="#FF9F43" FontWeight="Bold" Cursor="Hand" Click="BtnClearAnnivs_Click"/>
                                        <Button x:Name="BtnDelAnnivRow" Grid.Column="2" Content="🗑 Delete Row" Height="40" Background="#FF4757" FontWeight="Bold" Cursor="Hand" Click="BtnDeleteAnnivRow_Click" Visibility="Hidden"/>
                                        <Button Grid.Column="4" Content="💾 UPDATE DB" Height="40" Background="#2D3047" FontWeight="Bold" Cursor="Hand" Click="BtnSaveAnnivDb_Click"/>
                                        <Button Grid.Column="6" Content="🚀 PUSH LIVE" Height="40" Background="#00B478" FontWeight="Bold" Cursor="Hand" Click="BtnSubmitAnnivs_Click"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                    <!-- ======================================================= -->
                    <!-- SETTINGS DASHBOARD -->
                    <!-- ======================================================= -->
                    <Grid x:Name="SettingsDashboard" Visibility="Collapsed">
                        <Border Background="#1C1E30" CornerRadius="10" Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="⚙️ Global Settings" Foreground="#6C5DD3" FontWeight="Bold" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Configure global app behaviors and default media." Foreground="LightGray" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                                <!-- Default Theme Loop Setting -->
                                <Border Background="#0F111A" CornerRadius="10" Padding="20" Width="400">
                                    <StackPanel>
                                        <TextBlock Text="Default Background Theme Loop" Foreground="White" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                                        <TextBlock Text="This video will play silently on a continuous loop whenever you click 'Theme/Logo' or open the Live Display. Use a high-quality .mp4 file." Foreground="Gray" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="📂 Upload Theme Video" Height="35" Background="#6C5DD3" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnUploadThemeVideo_Click"/>
                                            <Button Grid.Column="2" Content="❌ Restore Black Screen" Height="35" Background="#FF4757" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnRestoreBlackTheme_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        <!-- Bible Scroll Sensitivity Setting -->
                        <Border Background="#0F111A" CornerRadius="10" Padding="20" Width="400" Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="Bible Chapter Scroll Sensitivity" Foreground="White" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                                <Slider x:Name="BibleScrollSensitivity" Minimum="1" Maximum="100" Value="20" TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <!-- NEW: Presentation Mode Gradient Picker -->
                        <Border Background="#0F111A" CornerRadius="10" Padding="20" Width="400" Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="Presentation Mode Gradient" Foreground="White" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                        <TextBlock Text="Color 1 (Hex):" Foreground="Gray" FontSize="11"/>
                                        <TextBox x:Name="TxtGrad1" Text="#0f2027" Background="#1C1E30" Foreground="White" BorderThickness="0" Padding="5"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                        <TextBlock Text="Color 2 (Hex):" Foreground="Gray" FontSize="11"/>
                                        <TextBox x:Name="TxtGrad2" Text="#203a43" Background="#1C1E30" Foreground="White" BorderThickness="0" Padding="5"/>
                                    </StackPanel>
                                </Grid>
                                <Button Content="💾 SAVE GRADIENT" Height="30" Background="#00B478" Foreground="White" FontWeight="Bold" Margin="0,10,0,0" Cursor="Hand" Click="BtnSaveGradient_Click"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                </Grid>
            </Border>
        </Grid>
        
    </Border>
</Window>